# Postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=grounded
POSTGRES_USER=grounded
POSTGRES_PORT=5432

# LLM planner (OpenAI-compatible)
GROUNDED_PLANNER_API_KEY=your_api_key_here
GROUNDED_PLANNER_MODEL=gpt-4o-mini
GROUNDED_PLANNER_BASE_URL=https://api.openai.com/v1/
GROUNDED_PLANNER_TIMEOUT_SECONDS=15

# LLM synthesizer (OpenAI-compatible)
GROUNDED_SYNTHESIS_API_KEY=your_api_key_here
GROUNDED_SYNTHESIS_MODEL=gpt-4o-mini

GROUNDED_REPLAY_MODE=false

# Cloudflare Tunnel (from: cloudflared tunnel token <tunnel-name>)
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here
